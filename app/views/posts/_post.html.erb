<div class="post">
  <h2><%= post.title %></h2>

  <!-- Show a short preview of the post body -->
  <p><%= truncate(post.body, length: 100) %></p>

  <!-- Show created date -->
  <small>Posted on <%= post.created_at.strftime("%b %d, %Y at %H:%M") %></small>

  <p>
    <%= link_to "Read more", post %>
  </p>
</div>