<div class="blog-grid">
  <% if @posts.any? %>
    <% @posts.each do |post| %>
      <div class="blog-card">
        <h3><%= link_to post.title, post %></h3>

        <p class="post-meta">
          By <%= post.user.email %> · <%= post.created_at.strftime("%b %d, %Y") %>
        </p>

        <p class="post-snippet">
          <%= truncate(post.body.to_plain_text, length: 120) %>
        </p>

        <%= link_to "Read →", post, class: "read-more" %>
      </div>
    <% end %>
  <% else %>
    <p>No posts yet.</p>
  <% end %>
</div>