<% content_for :title, "Home" %>

<div class="hero">
  <h1>GLASS BLOG</h1>
  <p>Thoughts, ideas, and stories</p>
</div>

<h2 style="margin-top: 2rem;">Latest Post</h2>

<div id="posts">
  <% if @latest_post %>
  <div class="post-card">
    <h2><%= link_to @latest_post.title, @latest_post %></h2>

    <p class="post-meta">
      By <%= @latest_post.user.email %> ·
      <%= @latest_post.created_at.strftime("%B %d, %Y") %>
    </p>

    <p class="post-snippet">
      <%= truncate(@latest_post.body.to_plain_text, length: 250) %>
    </p>

    <%= link_to "Read more →", @latest_post, class: "read-more" %>
  </div>
<% else %>
  <p>No published posts yet.</p>
<% end %>
</div>

<div style="margin-top: 2rem;">
  <%= link_to "View all posts →", blog_path, class: "btn" %>
</div>

<% if user_signed_in? %>
  <div style="margin-top: 1rem;">
    <%= link_to "New Post", new_post_path, class: "btn" %>
  </div>
<% end %>