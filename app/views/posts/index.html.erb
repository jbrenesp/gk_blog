<% content_for :title, "Home" %>

<div class="hero">
  <h1>GLASS BLOG</h1>
</div>

<div id="posts">
  <% if @posts.any? %>
    <% @posts.each do |post| %>
      <div class="post-card">
        <h2><%= link_to post.title, post %></h2>
        <p class="post-meta">By <%= post.user.email %> · <%= post.created_at.strftime("%B %d, %Y") %></p>
        <p class="post-snippet"><%= truncate(post.body.to_plain_text, length: 250) %></p>
        <%= link_to "Read more →", post, class: "read-more" %>
      </div>
    <% end %>
  <% else %>
    <p>No published posts yet.</p>
  <% end %>
</div>

<% if user_signed_in? %>
  <%= link_to "New Post", new_post_path, class: "btn" %>
<% end %>