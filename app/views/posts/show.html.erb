<p style="color: green"><%= notice %></p>

<h1><%= @post.title %></h1>

<% if @post.image.attached? %>
  <%= image_tag url_for(@post.image), width: 400 %>
<% end %>

<p><%= @post.body %></p>

<small>Posted on <%= @post.created_at.strftime("%b %d, %Y at %H:%M") %></small>

<p>Likes: <%= @post.likes %></p>

<% if session[:liked_posts]&.include?(@post.id) %>
  <button disabled>You already liked this 👍</button>
<% else %>
  <%= button_to "Like 👍", like_post_path(@post), method: :post %>
<% end %>

<div>
  <%= link_to "Edit this post", edit_post_path(@post) %> |
  <%= link_to "Back to posts", posts_path %>

  <%= button_to "Destroy this post", @post, method: :delete %>
</div>
  
  
