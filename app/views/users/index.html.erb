<h1>Users</h1>

<table class="users-table">
  <thead>
    <tr>
      <th>Email</th>
      <th>Role</th>
      <th>Actions</th>
    </tr>
  </thead>

  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= user.email %></td>

        <td>
          <span class="role-badge <%= user.role %>">
            <%= user.role %>
          </span>
        </td>

        <td>
          <% if user == current_user %>
            <em>You</em>
          <% else %>

            <%= form_with model: user, method: :patch, local: true do |f| %>

              <%= f.select :role,
                  User.roles.keys.map { |r| [r.titleize, r] },
                  selected: user.role %>

              <%= f.submit "Update", class: "btn-small" %>

            <% end %>

          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<div style="margin-top: 20px;">
  <%= link_to "Create User", new_user_path, class: "btn" %>
</div>